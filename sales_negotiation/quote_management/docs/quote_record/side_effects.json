{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "pricing_exception_request",
      "values": {
        "title": {
          "$template": "Pricing Exception Request for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "PRICING_EXCEPTION_REQUEST-{reference_no|id}"
        }
      }
    }
  ],
  "cancel": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "cancelled"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ],
  "issue": [
    {
      "type": "create_record",
      "target_doc": "deal_negotiation_case",
      "values": {
        "title": {
          "$template": "Deal Negotiation Case for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "DEAL_NEGOTIATION_CASE-{reference_no|id}"
        }
      }
    }
  ]
}
