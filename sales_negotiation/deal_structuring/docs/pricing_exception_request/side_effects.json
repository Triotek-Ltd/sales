{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "submit": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "submitted"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "approve": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "approved"
      }
    },
    {
      "type": "create_record",
      "target_doc": "quote_record",
      "values": {
        "title": {
          "$template": "Quote Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "QUOTE_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "reject": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "rejected",
        "approval_status": "rejected"
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
