  "runtime_hints": {
    "doc_key": "lead_record",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "turn raw prospects into qualified leads with documented outreach and qualification evidence",
      "actors": [
        "sales rep",
        "sales manager",
        "reviewer"
      ],
      "start_condition": "a target customer or lead source is identified",
      "ordered_steps": [
        "Capture the lead and basic prospect context.",
        "Advance qualified prospects into opportunity management."
      ],
      "primary_actions": [
        "create",
        "update",
        "convert",
        "close"
      ],
      "primary_transitions": [
        "lead_record: draft -> active",
        "lead_record: active -> qualified -> converted"
      ],
      "downstream_effects": [
        "feeds opportunity, negotiation, and forecast workflows"
      ],
      "action_actors": {
        "create": [
          "sales rep"
        ],
        "update": [
          "sales rep"
        ],
        "assign": [
          "sales rep"
        ],
        "archive": [
          "sales manager"
        ]
      }
    },
    "action_side_effects_file": "side_effects.json"
  },
  "dashboard": {
    "metric_blocks": [
      "kpis",
      "summaries",
      "charts",
      "reports",
      "records"
    ],
    "default_view": "list",
    "reporting_surface": "doc"
  }
