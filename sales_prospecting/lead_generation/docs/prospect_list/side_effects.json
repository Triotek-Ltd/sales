{
  "create": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "review": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "draft"
      }
    }
  ],
  "activate": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "active"
      }
    },
    {
      "type": "create_record",
      "target_doc": "lead_record",
      "values": {
        "title": {
          "$template": "Lead Record for {title|reference_no|id}"
        },
        "reference_no": {
          "$template": "LEAD_RECORD-{reference_no|id}"
        }
      }
    }
  ],
  "close": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "closed"
      }
    }
  ],
  "archive": [
    {
      "type": "update_current",
      "fields": {
        "workflow_state": "archived"
      }
    }
  ]
}
