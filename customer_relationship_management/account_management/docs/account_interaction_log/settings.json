  "runtime_hints": {
    "doc_key": "account_interaction_log",
    "supports_related_lookup": true,
    "supports_fetch_rules": true,
    "workflow_hints": {
      "business_objective": "capture account touchpoints, preserve relationship history, and hand off follow-up work to the right owner",
      "actors": [
        "account manager",
        "support representative",
        "sales manager"
      ],
      "start_condition": "an account interaction or follow-up event occurs",
      "ordered_steps": [
        "Record the interaction.",
        "Review the follow-up requirement.",
        "Archive when the interaction history is no longer active."
      ],
      "primary_actions": [
        "record",
        "review",
        "archive"
      ],
      "action_actors": {
        "record": [
          "account manager",
          "support representative"
        ],
        "review": [
          "sales manager"
        ],
        "archive": [
          "account manager"
        ]
      },
      "primary_transitions": [
        "account_interaction_log: active -> archived"
      ],
      "downstream_effects": [
        "supports customer-account follow-up, renewal visibility, and relationship audit history"
      ]
    },
    "action_side_effects_file": "side_effects.json"
  },
